{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EpisodeArcV9",
  "type": "object",
  "properties": {
    "work_id": {"type": "string", "minLength": 1},
    "episode_no": {"type": "integer", "minimum": 1},
    "scene_count": {"type": "integer", "minimum": 1},
    "sequence_count": {"type": "integer", "minimum": 1},
    "dramatic_question": {"type": "string", "minLength": 1},
    "act_structure": {"type": "array", "minItems": 1, "items": {"type": "object", "properties": {"act": {"type": "string", "minLength": 1}, "seq_span": {"type": "array", "minItems": 2, "maxItems": 2, "items": {"type": "integer", "minimum": 1}}, "function": {"type": "string", "minLength": 1}}, "required": ["act","seq_span","function"], "additionalProperties": false}},
    "entry_state": {"type": "string", "minLength": 1},
    "exit_state": {"type": "string", "minLength": 1},
    "turning_point": {"type": "object", "properties": {"seq_index": {"type": "integer", "minimum": 1}, "desc": {"type": "string", "minLength": 1}}, "required": ["seq_index","desc"], "additionalProperties": false},
    "central_conflict_axis": {"type": "string", "minLength": 1},
    "episode_function": {"type": "string", "minLength": 1},
    "core_dist": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "by": {"type": "string", "minLength": 1}
  },
  "required": ["work_id","episode_no","scene_count","sequence_count","dramatic_question","act_structure","entry_state","exit_state","turning_point","central_conflict_axis","episode_function","core_dist","by"],
  "additionalProperties": false
}
