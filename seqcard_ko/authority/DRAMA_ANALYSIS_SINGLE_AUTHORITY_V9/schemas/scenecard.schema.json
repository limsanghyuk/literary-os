    "core2": {"anyOf": [{"enum": ["ESTABLISH","ORACLE","INTRO","BOND","CONFLICT","REVERSAL","LOSS","PUNISH","REVELATION","REUNION","RELIEF","ROMANCE","PERIL","RESCUE","DESIRE","HOOK"]},{"type": "null"}]},
